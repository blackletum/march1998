$body "hands" "python_dualhands"

$body "hands" "python_bullets"

$body "hands" "python_speedload"


// 7 hit box(es)
$hbox 0 "Bip01 R Arm2" -0.620000 -2.510000 -2.060000 11.814240 2.420000 2.290000
$hbox 0 "Bip01 R Hand" -1.260000 -0.880000 -1.990000 4.110000 1.270000 2.050000
$hbox 0 "gun master" -14.920000 -1.740000 -0.750000 2.040000 6.320000 0.810000
$hbox 0 "cylinder" -2.180000 -1.210000 -1.370000 0.190000 1.210000 1.050000
